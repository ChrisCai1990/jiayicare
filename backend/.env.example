PORT=3000
MONGODB_URI=mongodb+srv://<用户名>:<密码>@cluster0.xxxxx.mongodb.net/jiayicare?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=30d
NODE_ENV=development

# 仅在对应账号不存在时使用；创建成功后可从运行环境中移除。
BOOTSTRAP_ADMIN_PASSWORD=
PLATFORM_ADMIN_PASSWORD=

# 演示/测试账号默认关闭，生产环境不要启用。
SEED_DEMO_ACCOUNTS=false
DEMO_ACCOUNT_PASSWORD=

# 固定验证码登录默认关闭；仅用于隔离的演示环境。
ENABLE_DEMO_LOGIN=false
DEMO_LOGIN_PHONE=
