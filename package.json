{
  "name": "jiayicare-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app",
    "admin",
    "staff",
    "backend"
  ],
  "scripts": {
    "dev:app": "cd app && npx expo start",
    "dev:admin": "cd admin && npm run dev",
    "dev:staff": "cd staff && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "serve:app": "npx serve app/dist -s -l $PORT",
    "serve:admin": "npx serve admin/dist -s -l $PORT",
    "serve:staff": "npx serve staff/dist -s -l $PORT",
    "build:app": "cd app && npm run export:web",
    "build:admin": "cd admin && npm run build",
    "build:staff": "cd staff && npm run build",
    "build": "npm run build:app && npm run build:admin && npm run build:staff",
    "test": "npm --workspace app test"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "serve": "^14.2.0",
    "vite": "^5.2.12"
  }
}
