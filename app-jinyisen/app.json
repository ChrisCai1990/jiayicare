{
  "expo": {
    "name": "金伊森",
    "slug": "jinyisen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1215"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "需要访问相册，以便上传体检报告照片",
        "NSCameraUsageDescription": "需要使用相机，以便拍摄体检报告"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1215"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.jiayicare.jinyisen",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "需要访问相册，以便上传体检报告照片",
          "cameraPermission": "需要使用相机，以便拍摄体检报告"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "87f6e7f1-8bbe-4969-8faf-1954318111a7"
      }
    },
    "owner": "chriscai"
  }
}
